.env
# THIS FILE SHOULD NOT BE COMMITTED WITH SECRETS
# Copy this file to '.env' locally and fill in the real secret values before running or deploying.

# Option A (preferred) - single connection string (pooler port 6543)
# Replace <DB_PASSWORD> and remove surrounding <> when you use it.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

# Option B - separate PG_* variables (alternative to DATABASE_URL)
#PGHOST=aws-0-ap-south-1.pooler.supabase.com
#PGPORT=6543
#PGUSER=postgres
#PGPASSWORD=<DB_PASSWORD>
#PGDATABASE=postgres

# Required for Supabase pooler SNI routing
SUPABASE_SNI_HOST=xxpwstplqknvwjfaldig.supabase.co

# App settings
NODE_ENV=production
PORT=10000
